{
  "name": "letterboxd-rss",
  "version": "0.1.0",
  "description": "Zero-dependency, strictly-typed fetcher and parser for a Letterboxd user's public diary RSS feed.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:dist": "pnpm build && vitest run --config vitest.dist.config.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.json": [
      "biome format --write --no-errors-on-unmatched"
    ]
  },
  "keywords": [
    "letterboxd",
    "rss",
    "diary",
    "films",
    "movies",
    "feed",
    "parser",
    "typescript"
  ],
  "author": "Anthony Liddle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anthony-liddle/letterboxd-rss.git"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
